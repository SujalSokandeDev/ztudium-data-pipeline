# ============================================================
# Pipeline Environment Variables
# Copy to .env and fill in your actual values
# ============================================================

# --- Supabase ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:YOUR-PASSWORD@db.your-project-ref.supabase.co:5432/postgres

# --- Google Credentials (local only, GitHub uses secrets) ---
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json

# --- Supabase Storage bucket name ---
AHREFS_STORAGE_BUCKET=ahrefs-exports

# --- Ahrefs export folder (local, for upload_csvs.py) ---
AHREFS_EXPORT_DIR=d:\Ztudium\Data Consolidation\Ahref's exported Data

# --- GitHub (for auto-triggering workflows from upload_csvs.py) ---
# Create a Personal Access Token at: github.com/settings/tokens
# Scope needed: repo (or just workflow for public repos)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=SujalSokandeDev/ztudium-data-pipeline

# --- Google Search Console Properties ---
GSC_PROPERTY_CITIESABC=sc-domain:citiesabc.com
GSC_PROPERTY_BUSINESSABC=sc-domain:businessabc.net
GSC_PROPERTY_HEDGETHINK=sc-domain:hedgethink.com
GSC_PROPERTY_FASHIONABC=sc-domain:fashionabc.org
GSC_PROPERTY_TRADERSDNA=sc-domain:tradersdna.com
GSC_PROPERTY_FREEDOMX=sc-domain:freedomx.com
GSC_PROPERTY_WISDOMIA=sc-domain:wisdomia.com
GSC_PROPERTY_SPORTSDNA=sc-domain:sportsdna.com
GSC_PROPERTY_INTELLIGENTHQ=sc-domain:intelligenthq.com

# --- Google Analytics 4 Property IDs ---
GA4_PROPERTY_CITIESABC=000000000
GA4_PROPERTY_BUSINESSABC=000000000
GA4_PROPERTY_HEDGETHINK=000000000
GA4_PROPERTY_FASHIONABC=000000000
GA4_PROPERTY_TRADERSDNA=000000000
GA4_PROPERTY_FREEDOMX=000000000
GA4_PROPERTY_WISDOMIA=000000000
GA4_PROPERTY_SPORTSDNA=000000000
GA4_PROPERTY_INTELLIGENTHQ=000000000
